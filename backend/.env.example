# Copy to backend/.env — never commit backend/.env

ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174,https://your-app.vercel.app

# Supabase → Settings → API
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
# JWT Secret (legacy HS256) from Dashboard → Settings → API → JWT Settings → "JWT Secret"
# Do NOT use anon or service_role keys here. Newer projects also need SUPABASE_URL for JWKS (ES256).
SUPABASE_JWT_SECRET=

# Google AI Studio → API key (Gemini + embeddings)
GOOGLE_API_KEY=

# Optional overrides
# GEMINI_CHAT_MODEL=gemini-2.0-flash
# GEMINI_EMBEDDING_MODEL=models/gemini-embedding-001
# EMBEDDING_DIMENSIONS=1536
# RAG_TOP_K=8
