# Copy to .env and fill from Supabase → Settings → API
# Never commit .env or the service_role key.

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
# Optional: after deploying supabase/functions/report-pdf-stream (see docs/supabase-report-pdfs-setup.md)
# VITE_USE_PDF_EDGE_STREAM=true
VITE_IMGBB_API_KEY=
# Optional: Storage quota in bytes for the admin “storage left” meter (match your Supabase plan; default 1 GiB).
# VITE_SUPABASE_STORAGE_QUOTA_BYTES=1073741824

# imgBB API key (client upload for report gallery + sector icons). Get a key at https://api.imgbb.com/ — never commit the real value.
# VITE_IMGBB_API_KEY=

# GA4 Measurement ID (public). Enables gtag.js site-wide + SPA page_view on route changes.
# Example: VITE_GA_MEASUREMENT_ID=G-CR4WNC0SK8
# VITE_GA_MEASUREMENT_ID=

# Optional: Looker Studio (GA4) embed URL for Admin → Overview traffic chart (`https://…` only).
# VITE_GA_ADMIN_EMBED_URL=https://lookerstudio.google.com/embed/reporting/…

# FastAPI AI service (no trailing slash) — local: http://localhost:8000
# VITE_AI_API_URL=http://localhost:8000
# Production (Railway): https://your-service.up.railway.app

# Payment emails — EmailJS (browser, see docs/emailjs-payment-setup.md)
# Public Key: EmailJS → Account → API Keys (safe in frontend)
VITE_EMAILJS_PUBLIC_KEY=SPiv5hJYU7QpGuRSw
# Private Key stays in EmailJS dashboard only — not used by this app (turn OFF “Use Private Key” in Account → Security)
# Service / template IDs: Email Services + Email Templates in EmailJS dashboard
VITE_EMAILJS_SERVICE_ID=service_2p79oig
VITE_EMAILJS_TEMPLATE_ID=template_xxxxx
# Client approve/reject — one template (see docs/emailjs-template-payment-response.md)
VITE_EMAILJS_TEMPLATE_PAYMENT_RESPONSE=template_xxxxx
# Legacy optional fallbacks if PAYMENT_RESPONSE is empty:
# VITE_EMAILJS_TEMPLATE_APPROVED=template_xxxxx
# VITE_EMAILJS_TEMPLATE_REJECTED=template_xxxxx
VITE_SITE_URL=http://localhost:5173
VITE_EMAILJS_ADMIN_EMAILS=lamplightmeh@gmail.com
